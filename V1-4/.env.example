# Переменные окружения Netlify
# После создания Telegram-бота через @BotFather скопируйте эти значения
# в: Site settings → Build & deploy → Environment → Environment variables.
# Локально: скопируйте в .env и используйте `netlify dev` для эмуляции функций.

# Токен Telegram-бота (из @BotFather)
BOT_TOKEN=123456789:ABCdefGHIjklmNOPqrsTUVwxyz

# ID чата/пользователя, куда бот шлёт заявки.
# Для личного чата: напишите боту → откройте https://api.telegram.org/bot<TOKEN>/getUpdates
# → скопируйте `chat.id` из результата.
TELEGRAM_CHAT_ID=123456789

# Rate-limit заявок с одного IP (опционально; дефолты 60 / 3).
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=3
