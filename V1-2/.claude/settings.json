{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(claude mcp list)",
      "Bash(claude mcp list *)",
      "Bash(winget --version)",
      "Bash(winget list *)",
      "Bash(winget search *)",
      "Bash(where *)",
      "Bash(git remote -v)",
      "Bash(git remote)",
      "Bash(npm ls)",
      "Bash(npm ls *)",
      "Bash(npm outdated)",
      "Bash(npm outdated *)",
      "Bash(npm view *)",
      "Bash(npm config get *)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Edit(d:/Doc/Claude/Сайт Семен/**)",
      "Edit(d:\\Doc\\Claude\\Сайт Семен\\**)",
      "Edit(D:/Doc/Claude/Сайт Семен/**)",
      "Write(d:/Doc/Claude/Сайт Семен/**)",
      "Write(d:\\Doc\\Claude\\Сайт Семен\\**)",
      "Write(D:/Doc/Claude/Сайт Семен/**)",
      "Edit(C:/Users/User/.claude/**)",
      "Edit(C:\\Users\\User\\.claude\\**)",
      "Write(C:/Users/User/.claude/**)",
      "Write(C:\\Users\\User\\.claude\\**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Glob|Grep|NotebookRead|WebFetch|WebSearch|TodoWrite|ToolSearch|Agent|Skill|EnterPlanMode|ExitPlanMode|ListMcpResourcesTool|ReadMcpResourceTool|AskUserQuestion|Monitor|CronList",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/auto-approve.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
